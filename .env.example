# Supabase — récupérés depuis Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxxxxxxxxxx
SUPABASE_SERVICE_ROLE_KEY=xxxxxxxxxxxx

# Google OAuth — récupérés depuis Google Cloud Console
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxxxxxx

# URL de l'app (utilisée pour les redirections OAuth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
